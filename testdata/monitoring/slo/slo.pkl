/*
 * Conformance Test: Create SLO
 *
 * This file defines the initial resource state for conformance testing.
 * The conformance test harness will apply this file first.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@datadog/monitoring/slo.pkl"
import "@datadog/datadog.pkl"

local stackName = "plugin-sdk-test-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK conformance test stack"
  }

  new formae.Target {
    label = "datadog-target"
    namespace = "DATADOG"
    config = new datadog.Config {
      apiKey = read("env:DD_API_KEY")
      appKey = read("env:DD_APP_KEY")
      site = read("env:DD_SITE")
    }
  }

  new slo.Slo {
    label = "plugin-sdk-test-slo"
    name = "formae-plugin-sdk-test-slo-\(testRunID)"
    sloType = "metric"
    description = "Conformance test SLO"
    tags = new Listing { "env:test"; "managed-by:formae" }

    thresholds = new Listing {
      new slo.SloThreshold {
        target = 99.0
        timeframe = "7d"
        warning = 99.5
      }
    }

    query = new slo.SloQuery {
      numerator = "sum:my.metric.good{*}.as_count()"
      denominator = "sum:my.metric.total{*}.as_count()"
    }
  }
}
