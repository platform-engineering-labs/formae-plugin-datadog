/*
 * Conformance Test: Update Logs Pipeline (in-place)
 *
 * Changes from pipeline.pkl:
 *   - name: added "-updated" suffix
 *   - filter.query: changed filter
 *   - tags: added
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@datadog/logs/pipeline.pkl"
import "@datadog/datadog.pkl"

local stackName = "plugin-sdk-test-stack"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK conformance test stack"
  }

  new formae.Target {
    label = "datadog-target"
    namespace = "DATADOG"
    config = new datadog.Config {
      apiKey = read("env:DD_API_KEY")
      appKey = read("env:DD_APP_KEY")
      site = read("env:DD_SITE")
    }
  }

  new pipeline.Pipeline {
    label = "plugin-sdk-test-pipeline"
    name = "formae-plugin-sdk-test-\(testRunID)-updated"           // CHANGED
    isEnabled = true
    filter = new pipeline.PipelineFilter {
      query = "source:test OR source:api"                           // CHANGED
    }
    tags = new Listing { "env:test"; "managed-by:formae" }          // ADDED
  }
}
